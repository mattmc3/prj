#!/bin/sh
# shellcheck disable=SC3043

##? prj - project jumper
SCRIPT_PATH="$(cd "$(dirname "$0")" && pwd)/$(basename "$0")"

# Common helpers
die()    { warn "$@"; exit "${ERR:-1}"; }
say()    { printf '%s\n' "$@"; }
warn()   { say "$@" >&2; }
noop()   { :; }
is_cmd() { command -v "$1" >/dev/null 2>&1; }
is_cmd local || alias local=noop

# Check dependencies
if ! is_cmd fzf; then
  die "fzf command not found"
elif ! is_cmd fd; then
  die "fd command not found"
elif ! is_cmd zoxide; then
  die "zoxide command not found"
elif ! is_cmd rg; then
  die "rg command not found"
fi

# Print usage information
usage() {
  say "prj:    The project jumper"
  say "usage:  prj [-h] [-i <shell>] [<query...>]"
}

# Initialize sh/bash/zsh
init_sh() {
  cat <<EOF
prj() {
  MY_SELECTION="\$("$SCRIPT_PATH" \$@)"
  if [ -n "\$MY_SELECTION" ] && [ -d "\$MY_SELECTION" ]; then
    cd "\$MY_SELECTION"
  else
    printf '%s\n' "\$MY_SELECTION"
  fi
  unset MY_SELECTION
}
# eval "\$("$SCRIPT_PATH" -i sh)"
EOF
}

# Initialize fish
init_fish() {
  cat <<EOF
function prj
    set selection ("$SCRIPT_PATH" \$argv)
    if test -n "\$selection" && test -d "\$selection"
        cd "\$selection"
    else
        printf '%s\n' \$selection
    end
end
# "$SCRIPT_PATH" -i fish | source
EOF
}

# Keep project frecency in a dedicated zoxide DB so this wrapper does not mix
# with global shell navigation history.
prj_zoxide_data_dir() {
  local data_dir

  data_dir="${XDG_DATA_HOME:-$HOME/.local/share}/prj/zoxide"
  mkdir -p "$data_dir" || return 1
  say "$data_dir"
}

# Live-scan git repos under PRJ_DIR and sync the dedicated zoxide DB.
# - Add repos discovered by this scan that are not in DB yet.
# - Remove stale DB entries that no longer exist in this scan.
# This keeps candidate membership driven by live filesystem state while letting
# zoxide maintain ranking from wrapper selections over time.
sync_prj_zoxide_db() {
  local prj_dir zo_data_dir candidates_file existing_file adds_file removes_file
  local hash_file current_hash previous_hash

  prj_dir="$1"
  zo_data_dir="$2"
  candidates_file="$(mktemp "${TMPDIR:-/tmp}/prj-candidates.XXXXXX")" || return 1
  existing_file="$(mktemp "${TMPDIR:-/tmp}/prj-existing.XXXXXX")" || {
    rm -f "$candidates_file"
    return 1
  }
  adds_file="$(mktemp "${TMPDIR:-/tmp}/prj-adds.XXXXXX")" || {
    rm -f "$candidates_file" "$existing_file"
    return 1
  }
  removes_file="$(mktemp "${TMPDIR:-/tmp}/prj-removes.XXXXXX")" || {
    rm -f "$candidates_file" "$existing_file" "$adds_file"
    return 1
  }
  hash_file="$zo_data_dir/.prj-scan.cksum"

  fd --type d --base-directory "$prj_dir" --hidden --no-ignore-vcs --max-depth 5 '\.git$' |
  sed -e "s|/.git/$||" -e "s|^|$prj_dir/|" |
  sort -u > "$candidates_file"

  current_hash="$(cksum < "$candidates_file" | awk '{print $1":"$2}')"
  if [ -f "$hash_file" ]; then
    previous_hash="$(cat "$hash_file" 2>/dev/null || true)"
  else
    previous_hash=
  fi
  if [ "$current_hash" = "$previous_hash" ]; then
    rm -f "$candidates_file" "$existing_file" "$adds_file" "$removes_file"
    return 0
  fi

  _ZO_DATA_DIR="$zo_data_dir" zoxide query -la --base-dir "$prj_dir" > "$existing_file" 2>/dev/null || :

  rg -Fvxf "$existing_file" "$candidates_file" > "$adds_file" || true
  rg -Fvxf "$candidates_file" "$existing_file" > "$removes_file" || true

  if [ -s "$adds_file" ]; then
    _ZO_DATA_DIR="$zo_data_dir" tr '\n' '\0' < "$adds_file" |
    xargs -0 -n 200 zoxide add >/dev/null 2>&1 || :
  fi

  if [ -s "$removes_file" ]; then
    _ZO_DATA_DIR="$zo_data_dir" tr '\n' '\0' < "$removes_file" |
    xargs -0 -n 200 zoxide remove >/dev/null 2>&1 || :
  fi

  printf '%s\n' "$current_hash" > "$hash_file"

  rm -f "$candidates_file" "$existing_file" "$adds_file" "$removes_file"
}

# Main function
main() {
  local show_help show_version init_shell query selection PRJ_DIR zo_data_dir
  PRJ_DIR="${PRJ_DIR:-$HOME/Projects}"

  # Parse options - just set variables
  while getopts "hi:v" opt; do
    case $opt in
      h) show_help=1 ;;
      v) show_version=1 ;;
      i) init_shell="$OPTARG" ;;
      ?) ERR=2 die ;;  # Error message already printed by getopts
    esac
  done

  # Collect query parameters
  shift $((OPTIND-1))
  query="$*"

  # Handle actions based on parsed options
  if [ "${show_help:-0}" -eq 1 ]; then
    usage
    exit 0
  elif [ "${show_version:-0}" -eq 1 ]; then
    say "prj ver 1.0.2"
    exit 0
  fi

  if [ -n "$init_shell" ]; then
    case "$init_shell" in
      sh|zsh|bash)
        init_sh
        exit 0
        ;;
      fish)
        init_fish
        exit 0
        ;;
      *)
        ERR=2 die "prj: Unsupported shell '$init_shell'"
        ;;
    esac
  fi

  # Handle tilde expansion
  case "$PRJ_DIR" in
    ~*) PRJ_DIR="$HOME${PRJ_DIR#~}" ;;
  esac

  # Check project directory exists
  if [ ! -d "$PRJ_DIR" ]; then
    die "prj: Project home directory not found '$PRJ_DIR'"
  fi

  zo_data_dir="$(prj_zoxide_data_dir)" || die "prj: Could not create zoxide data dir"
  sync_prj_zoxide_db "$PRJ_DIR" "$zo_data_dir"

  # zoxide query -ls returns score+path sorted by frecency from this dedicated
  # DB. We strip the score, then keep that order in fzf with --no-sort.
  selection=$(
    _ZO_DATA_DIR="$zo_data_dir" zoxide query -ls --base-dir "$PRJ_DIR" |
    awk -v prefix="$PRJ_DIR/" '{
      path = $0
      sub(/^[[:space:]]*[0-9.]+[[:space:]]+/, "", path)
      sub("^" prefix, "", path)
      print path
    }' |
    fzf --layout=reverse-list --no-sort --query="$query"
  )

  # Output the selected project directory
  if [ -n "$selection" ] && [ -d "$PRJ_DIR/$selection" ]; then
    _ZO_DATA_DIR="$zo_data_dir" zoxide add "$PRJ_DIR/$selection" >/dev/null 2>&1 || :
    say "$PRJ_DIR/$selection"
  fi
}

# Run the script
main "$@"

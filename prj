#!/bin/sh
# shellcheck disable=SC3043

##? prj - project jumper
SCRIPT_PATH="$(cd "$(dirname "$0")" && pwd)/$(basename "$0")"

# Common helpers
die()    { warn "$@"; exit "${ERR:-1}"; }
say()    { printf '%s\n' "$@"; }
warn()   { say "$@" >&2; }
noop()   { :; }
is_cmd() { command -v "$1" >/dev/null 2>&1; }
is_cmd local || alias local=noop

# Check dependencies
if ! is_cmd fzf; then
  die "fzf command not found"
elif ! is_cmd fd; then
  die "fd command not found"
fi

# Print usage information
usage() {
  say "prj:    The project jumper"
  say "usage:  prj [-h] [-i <shell>] [<query...>]"
}

# Initialize sh/bash/zsh
init_sh() {
  cat <<EOF
prj() {
  MY_SELECTION="\$("$SCRIPT_PATH" \$@)"
  if [ -n "\$MY_SELECTION" ] && [ -d "\$MY_SELECTION" ]; then
    cd "\$MY_SELECTION"
  else
    printf '%s\n' "\$MY_SELECTION"
  fi
  unset MY_SELECTION
}
# eval "\$("$SCRIPT_PATH" -i sh)"
EOF
}

# Initialize fish
init_fish() {
  cat <<EOF
function prj
    set selection ("$SCRIPT_PATH" \$argv)
    if test -n "\$selection" && test -d "\$selection"
        cd "\$selection"
    else
        printf '%s\n' \$selection
    end
end
# "$SCRIPT_PATH" -i fish | source
EOF
}

now_epoch() {
  date +%s
}

# Frecency state lives in a TSV file at:
#   <state_dir>/frecency.tsv
# Each row is:
#   relative_project_path<TAB>score<TAB>last_access_epoch<TAB>hit_count
prj_state_file() {
  local state_dir

  state_dir="${XDG_STATE_HOME:-$HOME/.local/state}/prj"
  mkdir -p "$state_dir" || return 1
  say "$state_dir/frecency.tsv"
}

# Rank discovered projects by a decayed score so recent picks matter more while
# still preserving long-term frequent usage. Half-life defaults to 14 days.
rank_candidates_by_frecency() {
  local db_file now half_life_days half_life_sec tab

  db_file="$1"
  now="$2"
  half_life_days="${PRJ_FRECENCY_HALFLIFE_DAYS:-14}"
  case "$half_life_days" in
    ''|*[!0-9]*) half_life_days=14 ;;
  esac
  if [ "$half_life_days" -le 0 ]; then
    half_life_days=14
  fi
  half_life_sec=$((half_life_days * 86400))
  tab="$(printf '\t')"

  if [ -z "$db_file" ] || [ ! -f "$db_file" ]; then
    awk -F "$tab" -v OFS="$tab" '{ print 0, $0 }' |
    sort -t "$tab" -k1,1nr -k2,2 |
    cut -f2-
    return
  fi

  awk -F "$tab" -v OFS="$tab" -v now="$now" -v hls="$half_life_sec" '
    NR == FNR {
      hist_score[$1] = $2 + 0
      hist_last[$1] = $3 + 0
      next
    }
    {
      p = $0
      s = 0
      if (p in hist_score) {
        dt = now - hist_last[p]
        if (dt < 0) dt = 0
        # Exponential decay: score * 0.5^(age/half_life)
        s = hist_score[p] * exp(log(0.5) * (dt / hls))
      }
      print s, p
    }
  ' "$db_file" - |
  sort -t "$tab" -k1,1nr -k2,2 |
  cut -f2-
}

# Apply decay to all tracked projects, then reward the chosen project with +1.
# This keeps scores bounded over time while letting recent usage bubble up.
update_frecency() {
  local selected db_file now half_life_days half_life_sec tab tmp_file

  selected="$1"
  db_file="$2"
  now="$3"

  if [ -z "$selected" ] || [ -z "$db_file" ]; then
    return 0
  fi

  half_life_days="${PRJ_FRECENCY_HALFLIFE_DAYS:-14}"
  case "$half_life_days" in
    ''|*[!0-9]*) half_life_days=14 ;;
  esac
  if [ "$half_life_days" -le 0 ]; then
    half_life_days=14
  fi
  half_life_sec=$((half_life_days * 86400))
  tab="$(printf '\t')"
  tmp_file="${db_file}.tmp.$$"

  if [ ! -f "$db_file" ]; then
    : > "$db_file" || return 1
  fi

  awk -F "$tab" -v OFS="$tab" -v target="$selected" -v now="$now" -v hls="$half_life_sec" '
    function decayed(score, last, dt) {
      dt = now - last
      if (dt < 0) dt = 0
      return score * exp(log(0.5) * (dt / hls))
    }
    NF >= 4 {
      p = $1
      s = $2 + 0
      l = $3 + 0
      h = $4 + 0
      s = decayed(s, l)
      if (p == target) {
        s = s + 1
        l = now
        h = h + 1
        seen = 1
      }
      print p, s, l, h
      next
    }
    END {
      if (!seen) print target, 1, now, 1
    }
  ' "$db_file" > "$tmp_file" && mv "$tmp_file" "$db_file"
}

# Main function
main() {
  local show_help show_version init_shell query selection PRJ_DIR now db_file
  PRJ_DIR="${PRJ_DIR:-$HOME/Projects}"

  # Parse options - just set variables
  while getopts "hi:v" opt; do
    case $opt in
      h) show_help=1 ;;
      v) show_version=1 ;;
      i) init_shell="$OPTARG" ;;
      ?) ERR=2 die ;;  # Error message already printed by getopts
    esac
  done

  # Collect query parameters
  shift $((OPTIND-1))
  query="$*"

  # Handle actions based on parsed options
  if [ "${show_help:-0}" -eq 1 ]; then
    usage
    exit 0
  elif [ "${show_version:-0}" -eq 1 ]; then
    say "prj ver 1.0.2"
    exit 0
  fi

  if [ -n "$init_shell" ]; then
    case "$init_shell" in
      sh|zsh|bash)
        init_sh
        exit 0
        ;;
      fish)
        init_fish
        exit 0
        ;;
      *)
        ERR=2 die "prj: Unsupported shell '$init_shell'"
        ;;
    esac
  fi

  # Handle tilde expansion
  case "$PRJ_DIR" in
    ~*) PRJ_DIR="$HOME${PRJ_DIR#~}" ;;
  esac

  # Check project directory exists
  if [ ! -d "$PRJ_DIR" ]; then
    die "prj: Project home directory not found '$PRJ_DIR'"
  fi

  now="$(now_epoch)"
  db_file="$(prj_state_file)" || db_file=

  # Build candidates, rank by frecency, then preserve that order in fzf.
  # --no-sort is important: fzf should not re-rank our pre-scored list.
  selection=$(
    fd --type d --base-directory "$PRJ_DIR" --hidden --no-ignore-vcs --max-depth 5 '\.git$' |
    sed -e "s|/.git/$||" |
    rank_candidates_by_frecency "$db_file" "$now" |
    fzf --layout=reverse-list --no-sort --query="$query"
  )

  # Output the selected project directory
  if [ -n "$selection" ] && [ -d "$PRJ_DIR/$selection" ]; then
    update_frecency "$selection" "$db_file" "$now"
    say "$PRJ_DIR/$selection"
  fi
}

# Run the script
main "$@"

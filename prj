#!/bin/sh
# shellcheck disable=SC3043

##? prj - project jumper
SCRIPT_PATH="$(cd "$(dirname "$0")" && pwd)/$(basename "$0")"

# Common helpers
die()    { warn "$@"; exit "${ERR:-1}"; }
say()    { printf '%s\n' "$@"; }
warn()   { say "$@" >&2; }
noop()   { :; }
is_cmd() { command -v "$1" >/dev/null 2>&1; }
is_cmd local || alias local=noop

# Check dependencies
if ! is_cmd fzf; then
  die "fzf command not found"
elif ! is_cmd fd; then
  die "fd command not found"
elif ! is_cmd zoxide; then
  die "zoxide command not found"
fi

# Print usage information
usage() {
  say "prj:    The project jumper"
  say "usage:  prj [-h] [-i <shell>] [<query...>]"
}

# Initialize sh/bash/zsh
init_sh() {
  cat <<EOF
prj() {
  MY_SELECTION="\$("$SCRIPT_PATH" \$@)"
  if [ -n "\$MY_SELECTION" ] && [ -d "\$MY_SELECTION" ]; then
    cd "\$MY_SELECTION"
  else
    printf '%s\n' "\$MY_SELECTION"
  fi
  unset MY_SELECTION
}
# eval "\$("$SCRIPT_PATH" -i sh)"
EOF
}

# Initialize fish
init_fish() {
  cat <<EOF
function prj
    set selection ("$SCRIPT_PATH" \$argv)
    if test -n "\$selection" && test -d "\$selection"
        cd "\$selection"
    else
        printf '%s\n' \$selection
    end
end
# "$SCRIPT_PATH" -i fish | source
EOF
}

# Keep project frecency in a dedicated zoxide DB so this wrapper does not mix
# with global shell navigation history.
prj_zoxide_data_dir() {
  local data_dir

  data_dir="${XDG_DATA_HOME:-$HOME/.local/share}/prj/zoxide"
  mkdir -p "$data_dir" || return 1
  say "$data_dir"
}

# Rank live-scanned candidates using existing zoxide scores.
# Only projects that have been selected before in this wrapper will have
# positive scores; everything else gets score 0 and is then sorted by path.
rank_live_candidates_with_zoxide() {
  local prj_dir zo_data_dir candidates_file scores_file ranked_file tab

  prj_dir="$1"
  zo_data_dir="$2"
  tab="$(printf '\t')"
  candidates_file="$(mktemp "${TMPDIR:-/tmp}/prj-candidates.XXXXXX")" || return 1
  scores_file="$(mktemp "${TMPDIR:-/tmp}/prj-scores.XXXXXX")" || {
    rm -f "$candidates_file"
    return 1
  }
  ranked_file="$(mktemp "${TMPDIR:-/tmp}/prj-ranked.XXXXXX")" || {
    rm -f "$candidates_file" "$scores_file"
    return 1
  }

  fd --type d --base-directory "$prj_dir" --hidden --no-ignore-vcs --max-depth 5 '\.git$' |
  sed -e "s|/.git/$||" |
  sort -u > "$candidates_file"

  _ZO_DATA_DIR="$zo_data_dir" zoxide query -ls --base-dir "$prj_dir" 2>/dev/null |
  awk -v pfx="$prj_dir/" -v OFS="$tab" '
    {
      score = $1
      path = $0
      sub(/^[[:space:]]*[0-9.]+[[:space:]]+/, "", path)
      sub("^" pfx, "", path)
      print path, score
    }
  ' > "$scores_file" || :

  # When the scores file is empty (no prior selections) NR==FNR would be true
  # throughout the candidates file, so handle the cold-start case explicitly.
  if [ -s "$scores_file" ]; then
    awk -F "$tab" -v OFS="$tab" '
      NR == FNR {
        score[$1] = $2
        next
      }
      {
        s = ($0 in score) ? score[$0] : 0
        print s, $0
      }
    ' "$scores_file" "$candidates_file" |
    sort -t "$tab" -k1,1nr -k2,2 > "$ranked_file"
    cut -f2- "$ranked_file"
  else
    cat "$candidates_file"
  fi

  rm -f "$candidates_file" "$scores_file" "$ranked_file"
}

# Main function
main() {
  local show_help show_version init_shell query selection PRJ_DIR zo_data_dir
  PRJ_DIR="${PRJ_DIR:-$HOME/Projects}"

  # Parse options - just set variables
  while getopts "hi:v" opt; do
    case $opt in
      h) show_help=1 ;;
      v) show_version=1 ;;
      i) init_shell="$OPTARG" ;;
      ?) ERR=2 die ;;  # Error message already printed by getopts
    esac
  done

  # Collect query parameters
  shift $((OPTIND-1))
  query="$*"

  # Handle actions based on parsed options
  if [ "${show_help:-0}" -eq 1 ]; then
    usage
    exit 0
  elif [ "${show_version:-0}" -eq 1 ]; then
    say "prj ver 1.0.2"
    exit 0
  fi

  if [ -n "$init_shell" ]; then
    case "$init_shell" in
      sh|zsh|bash)
        init_sh
        exit 0
        ;;
      fish)
        init_fish
        exit 0
        ;;
      *)
        ERR=2 die "prj: Unsupported shell '$init_shell'"
        ;;
    esac
  fi

  # Handle tilde expansion
  case "$PRJ_DIR" in
    ~*) PRJ_DIR="$HOME${PRJ_DIR#~}" ;;
  esac

  # Check project directory exists
  if [ ! -d "$PRJ_DIR" ]; then
    die "prj: Project home directory not found '$PRJ_DIR'"
  fi

  zo_data_dir="$(prj_zoxide_data_dir)" || die "prj: Could not create zoxide data dir"

  # Live-scan candidates every run, rank with existing zoxide data, then keep
  # that order in fzf using --no-sort.
  selection=$(
    rank_live_candidates_with_zoxide "$PRJ_DIR" "$zo_data_dir" |
    fzf --layout=reverse-list --no-sort --query="$query"
  )

  # Output the selected project directory
  if [ -n "$selection" ] && [ -d "$PRJ_DIR/$selection" ]; then
    (
      _ZO_DATA_DIR="$zo_data_dir" zoxide add "$PRJ_DIR/$selection" >/dev/null 2>&1 || :
    )
    say "$PRJ_DIR/$selection"
  fi
}

# Run the script
main "$@"
